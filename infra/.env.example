# Copy to infra/.env and customize as needed.

POSTGRES_DB=snackattack
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Leave blank to use compose default local connection string.
# BACKEND_DB_CONNECTION=Host=db;Port=5432;Database=snackattack;Username=postgres;Password=postgres

BACKEND_JWT_ISSUER=snackAttackPOS
BACKEND_JWT_AUDIENCE=snackAttackPOSClients
BACKEND_JWT_KEY=dev-only-super-secret-key-change-me

APP_TIMEZONE=UTC

FRONTEND_API_URL=http://localhost:5000
FRONTEND_ML_URL=http://localhost:8001
